      "targets": [{ "datasource": { "type": "prometheus", "uid": "$datasource" }, "expr": "100 * sum(node_cilium_ct_dns_entries_by_pod{cluster_name=~\"$cluster_name\", node=~\"$node\", pod!=\"unknown\"}) / (sum(node_cilium_ct_entries_by_pod{cluster_name=~\"$cluster_name\", node=~\"$node\", pod!=\"unknown\"}) + sum(node_cilium_ct_dns_entries_by_pod{cluster_name=~\"$cluster_name\", node=~\"$node\", pod!=\"unknown\"}))", "legendFormat": "DNS %", "refId": "A" }]
    },
