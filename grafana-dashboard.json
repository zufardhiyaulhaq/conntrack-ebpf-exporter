      "title": "Total CT Entries",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "$datasource" }, "expr": "sum(node_cilium_ct_entries_by_pod{cluster_name=~\"$cluster_name\", node=~\"$node\", pod!=\"unknown\", pod!=\"node\", namespace=~\"$namespace\", app=~\"$app\"})", "legendFormat": "Total", "refId": "A" }]
